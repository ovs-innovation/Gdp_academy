NODE_ENV=production
PORT=8096
HOST=0.0.0.0

MONGO_URI=your_mongodb_uri
JWT_SECRET=your_jwt_secret

# Gmail app password (Google Account → Security → App passwords)
EMAIL_USER=your@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
ADMIN_EMAIL=your@gmail.com

# Public site + admin panel (used for emails and production CORS allowlist)
FRONTEND_URL=https://garimadanceproductions.com
ADMIN_URL=https://admin.garimadanceproductions.com

# Optional comma-separated extra CORS origins (production only)
# CORS_ORIGINS=https://staging.example.com

CLASS_EMAIL_NOTIFY_STUDENTS=true
